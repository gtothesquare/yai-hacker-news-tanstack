{
  "name": "yai-hacker-news-tanstack",
  "version": "1.0.0",
  "description": "yet another anther hacker news clone, this time tan stack",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "lint": "pnpm eslint . --fix",
    "typecheck": "tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "prepare": "husky",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.26",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "inngest": "4.6.0",
    "nitro": "3.0.260610-beta",
    "postcss": "8.5.15",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.1",
    "timeago.js": "4.0.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "2.0.0",
    "@tailwindcss/forms": "0.5.11",
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "0.31.10",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "tsc-files": "1.1.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": "tsc-files --noEmit",
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
